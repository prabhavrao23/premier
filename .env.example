# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

DATABASE_URL=jdbc:postgresql://localhost:5432/pl_data
DB_USER=postgres
DB_PASSWORD=your_password_here

# Set to your Vercel frontend URL in production (e.g. https://prem-zone.vercel.app)
FRONTEND_URL=http://localhost:5173

# PORT is set automatically by Railway; leave unset locally (defaults to 8080)
# PORT=8080
